PORT=3001
NODE_ENV=development

# PostgreSQL connection string
DATABASE_URL=postgres://postgres:postgres@localhost:5432/innoinvest

# Sync model schema to the database on startup (code-first). Use only in development.
DB_SYNC=true

# Google Gemini API key — free at https://aistudio.google.com (no credit card required)
# Free tier: 1,500 requests/day, 15 requests/minute
# Model used: gemini-2.5-flash
GEMINI_API_KEY=
