{
  "name": "innoinvest-backend",
  "version": "1.0.0",
  "description": "InnoiNVest backend API",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "mcp": "node src/mcp/server.js",
    "db:sync": "DB_SYNC=true node -e \"require('dotenv').config(); require('./src/models').sequelize.sync({ alter: true }).then(() => { console.log('Schema updated.'); process.exit(0); }).catch((e) => { console.error(e); process.exit(1); })\"",
    "seed:population": "node src/seeders/population.seeder.js",
    "seed:population:force": "node src/seeders/population.seeder.js --force",
    "seed:universities": "node src/seeders/university.seeder.js",
    "seed:universities:force": "node src/seeders/university.seeder.js --force"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "node-html-parser": "^7.1.0",
    "openai": "^6.39.0",
    "pg": "^8.21.0",
    "sequelize": "^6.37.8",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "nodemon": "^3.1.9"
  }
}
